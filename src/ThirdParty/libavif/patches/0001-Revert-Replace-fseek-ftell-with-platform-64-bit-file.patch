From 55a4c40464b509d1b93e0940b97bbd41829b0be7 Mon Sep 17 00:00:00 2001
From: Peter Zhigalov <peter.zhigalov@gmail.com>
Date: Sat, 2 May 2026 14:25:22 +0700
Subject: [PATCH] Revert "Replace fseek,ftell with platform 64-bit file APIs"

This reverts commit ab8347b75b15fcfc71ef424e45fb6e0e1b530877.
---
 src/io.c | 30 +++---------------------------
 1 file changed, 3 insertions(+), 27 deletions(-)

diff --git a/src/io.c b/src/io.c
index 2fc0bf23..e43bdb5f 100644
--- a/src/io.c
+++ b/src/io.c
@@ -142,37 +142,13 @@ avifIO * avifIOCreateFileReader(const char * filename)
         return NULL;
     }
 
-#if defined(_WIN32)
-    // Windows uses _fseeki64 / _ftelli64 for large file support
-    if (_fseeki64(f, 0, SEEK_END) != 0) {
-        fclose(f);
-        return NULL;
-    }
-    __int64 fileSize = _ftelli64(f);
-    if (fileSize < 0) {
-        fclose(f);
-        return NULL;
-    }
-    if (_fseeki64(f, 0, SEEK_SET) != 0) {
-        fclose(f);
-        return NULL;
-    }
-#else
-    // POSIX large file support
-    if (fseeko(f, 0, SEEK_END) != 0) {
-        fclose(f);
-        return NULL;
-    }
-    off_t fileSize = ftello(f);
+    fseek(f, 0, SEEK_END);
+    long fileSize = ftell(f);
     if (fileSize < 0) {
         fclose(f);
         return NULL;
     }
-    if (fseeko(f, 0, SEEK_SET) != 0) {
-        fclose(f);
-        return NULL;
-    }
-#endif
+    fseek(f, 0, SEEK_SET);
 
     avifIOFileReader * reader = (avifIOFileReader *)avifAlloc(sizeof(avifIOFileReader));
     if (!reader) {
-- 
2.47.3

